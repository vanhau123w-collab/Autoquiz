<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base size 108dp x 108dp -->
    <item android:width="108dp" android:height="108dp" android:drawable="@android:color/transparent" />

    <!-- Backdrop (Purple tilted) - size 40x40 -->
    <item
        android:width="40dp"
        android:height="40dp"
        android:gravity="center">
        <rotate android:fromDegrees="-8" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="@color/figma_purple" />
                <corners android:radius="10dp" />
            </shape>
        </rotate>
    </item>

    <!-- Main Shape (Orange) - size 38x38 -->
    <item
        android:width="38dp"
        android:height="38dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <gradient android:angle="225" android:startColor="#FF8A00" android:endColor="#FF3D00" android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- Text AQ Vector -->
    <item
        android:width="22dp"
        android:height="22dp"
        android:gravity="center"
        android:drawable="@drawable/ic_aq_text" />

    <!-- Yellow badge (Top Right) - Top 28, Right 28 -->
    <item
        android:width="14dp"
        android:height="14dp"
        android:gravity="top|end"
        android:top="28dp"
        android:right="28dp">
        <shape android:shape="oval">
            <solid android:color="#FACC15" />
            <!-- Thêm viền trắng mỏng cho huy hiệu để phân tách rõ khỏi nền cam -->
            <stroke android:width="1dp" android:color="@android:color/white"/>
        </shape>
    </item>
    
    <item
        android:width="8dp"
        android:height="8dp"
        android:gravity="top|end"
        android:top="31dp"
        android:right="31dp"
        android:drawable="@drawable/ic_bolt_white" />

    <!-- Green badge (Bottom Left) - Bottom 28, Left 28 -->
    <item
        android:width="14dp"
        android:height="14dp"
        android:gravity="bottom|start"
        android:bottom="28dp"
        android:left="28dp">
        <shape android:shape="oval">
            <solid android:color="#22C55E" />
            <stroke android:width="1dp" android:color="@android:color/white"/>
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="8dp"
        android:gravity="bottom|start"
        android:bottom="31dp"
        android:left="31dp"
        android:drawable="@drawable/ic_check_white" />
</layer-list>
