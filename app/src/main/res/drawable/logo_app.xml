<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Transparent Background Padding to make room for badges -->
    <item android:drawable="@android:color/transparent" />

    <!-- Backdrop (Purple tilted) -->
    <item
        android:height="75dp"
        android:width="75dp"
        android:gravity="center">
        <rotate android:fromDegrees="-8" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="@color/figma_purple" />
                <corners android:radius="24dp" />
            </shape>
        </rotate>
    </item>

    <!-- Main Shape (Orange) -->
    <item
        android:height="75dp"
        android:width="75dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <gradient
                android:angle="225"
                android:startColor="#FF8A00"
                android:endColor="#FF3D00"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Text AQ Vector -->
    <item
        android:height="40dp"
        android:width="40dp"
        android:gravity="center"
        android:drawable="@drawable/ic_aq_text" />

    <!-- Yellow badge (Top Right) -->
    <item
        android:width="26dp"
        android:height="26dp"
        android:gravity="top|end"
        android:top="16dp"
        android:right="16dp">
        <shape android:shape="oval">
            <solid android:color="#FACC15" />
        </shape>
    </item>
    
    <!-- Bolt icon in Yellow badge -->
    <item
        android:width="14dp"
        android:height="14dp"
        android:gravity="top|end"
        android:top="22dp"
        android:right="22dp"
        android:drawable="@drawable/ic_bolt_white" />

    <!-- Green badge (Bottom Left) -->
    <item
        android:width="26dp"
        android:height="26dp"
        android:gravity="bottom|start"
        android:bottom="16dp"
        android:left="16dp">
        <shape android:shape="oval">
            <solid android:color="#22C55E" />
        </shape>
    </item>

    <!-- Check icon in Green badge -->
    <item
        android:width="14dp"
        android:height="14dp"
        android:gravity="bottom|start"
        android:bottom="22dp"
        android:left="22dp"
        android:drawable="@drawable/ic_check_white" />

</layer-list>
