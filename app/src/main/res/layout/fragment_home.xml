<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/home_welcome_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Hello, John Doe! 👋"
            android:textColor="@color/on_surface"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ready to learn something new?"
            android:textColor="@color/on_surface_secondary"
            android:textSize="14sp" />

        <!-- Streak Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current_streak"
                            android:textColor="@color/on_surface_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="bottom"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/streak_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/secondary"
                                android:textSize="40sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="8dp"
                                android:text="@string/days"
                                android:textColor="@color/on_surface_secondary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/streak_motto"
                            android:textColor="@color/on_surface_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="🔥"
                        android:textSize="32sp" />
                </RelativeLayout>

                <!-- Weekdays -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="7">

                    <!-- Day Template (Mon) -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_1" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_2" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_3" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_4" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_5" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_6" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_home_day_7" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_streak_circle" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textSize="10sp" android:textColor="@color/on_surface_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:text="@string/your_stats"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Stats Grid (Horizontal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:padding="16dp">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_icon_blue" android:backgroundTint="@color/success_container">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="◎" android:textColor="@color/success" android:textSize="16sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv_accuracy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="@color/on_surface" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/accuracy" android:textColor="@color/on_surface_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginHorizontal="6dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:padding="16dp">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_icon_blue">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="📚" android:textColor="@color/primary" android:textSize="14sp" />
                    </FrameLayout>
                    <TextView android:id="@+id/tv_total_quizzes_stat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/on_surface" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/quizzes_count" android:textColor="@color/on_surface_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:padding="16dp">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_icon_blue" android:backgroundTint="@color/tertiary_container">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="⏱" android:textColor="@color/tertiary" android:textSize="14sp" />
                    </FrameLayout>
                    <TextView android:id="@+id/tv_avg_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0s" android:textColor="@color/on_surface" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/avg_time" android:textColor="@color/on_surface_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recently_added"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_see_all_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/see_all"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Horizontal scrollView for Recently Added -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingEnd="24dp">
            
            <LinearLayout
                android:id="@+id/recently_added_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <!-- Dynamic cards will be added here -->

            </LinearLayout>
        </HorizontalScrollView>

        <Button
            android:id="@+id/btn_create_quiz"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:text="@string/btn_create_quiz"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_library"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip_selector"
            app:backgroundTint="@color/white"
            android:stateListAnimator="@null"
            android:text="@string/btn_library"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>