<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/create_quiz_title"
            android:textColor="@color/on_surface"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Quiz Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/quiz_title_label"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_quiz_title"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/quiz_title_hint"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline_variant"
            android:textSize="14sp" />

        <!-- Content label + buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/your_text_label"
                android:textStyle="bold"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btn_ai_settings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/primary" />

            <ImageButton
                android:id="@+id/btn_upload_docx"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_upload"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Content input -->
        <EditText
            android:id="@+id/et_content"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top|start"
            android:hint="@string/content_hint"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline_variant"
            android:textSize="14sp" />

        <!-- Custom Prompt (collapsible chip style) -->
        <LinearLayout
            android:id="@+id/btn_toggle_prompt"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_chip_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦ Custom Prompt"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_prompt_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="▾"
                android:textColor="@color/primary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_prompt_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ghi đè prompt mặc định. Đặt {source} để chèn nội dung văn bản."
                android:textColor="@color/on_surface_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_custom_prompt"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="Ví dụ: Tạo {quantity} câu hỏi từ nội dung sau: {source}"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline_variant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Number of questions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/num_questions_label"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_q5"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_selector"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="5"
                android:textColor="@color/color_chip_text"
                android:textSize="14sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_q10"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_chip_selector"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="10"
                android:textColor="@color/color_chip_text"
                android:textSize="14sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_q15"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_chip_selector"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="15"
                android:textColor="@color/color_chip_text"
                android:textSize="14sp"
                android:textAllCaps="false" />

            <!-- Custom number input -->
            <EditText
                android:id="@+id/et_custom_quantity"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:hint="Tự nhập"
                android:inputType="number"
                android:maxLength="2"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline_variant"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tối đa 20 câu"
            android:textColor="@color/on_surface_secondary"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_generate_quiz"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_chip_selector"
            android:backgroundTint="#CBD5E1"
            app:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:text="@string/btn_generate_quiz"
            android:textColor="@color/on_surface_variant"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
